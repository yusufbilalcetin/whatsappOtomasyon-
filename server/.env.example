# --- Firebase ---
# service-account.json dosyasinin yolu (Firebase Console > Project Settings > Service accounts)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- Gemini ---
# https://aistudio.google.com/app/apikey adresinden alinir (ucretsiz)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Genel ---
PORT=3000
DEFAULT_TIMEZONE=Europe/Istanbul

# WhatsApp oturum bilgilerinin saklanacagi klasor
WA_AUTH_DIR=./auth_info

# Panel icin basit parola korumasi (bos birakilirsa korumasiz)
PANEL_PASSWORD=
