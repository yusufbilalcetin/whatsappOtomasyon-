# Firebase: yerel/cihazda ADC kullaniliyor (gcloud auth application-default login).
# GCP/Oracle VM disinda calistiriyorsan service-account.json da koyabilirsin.
GOOGLE_CLOUD_PROJECT=whatsappotomasyon-5d7a5

# Gemini (opsiyonel; sadece 'ai' modlu otomasyon icin gerekli)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

DEFAULT_TIMEZONE=Europe/Istanbul
WA_AUTH_DIR=./auth_info
